{
  "name": "krypto-steuer-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='(konsistenz|barcode|historische-preise|multi-wallet|endbestand|jahres-support|pdf-generierung|security|erc20-sol|fifo|csv-parser|steuerwert-31-12|price-service|kurs-steuerwert|barcode-ech0270|barcode-layout)'",
    "test:vercel": "jest --testPathPattern='vercel-kompatibilitaet' --testTimeout=120000",
    "test:realwallet": "jest --testPathPattern='real-wallet' --testTimeout=180000",
    "test:all": "jest --runInBand",
    "test:pre-deploy": "npm run test:unit && npm run test:vercel && npm run test:realwallet"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "bwip-js": "^4.8.0",
    "next": "16.1.6",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-jest": "^29.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "tailwindcss": "^4"
  }
}
