# ─────────────────────────────────────────────────────────────────────────────
# .env.example – Vorlage für Umgebungsvariablen
# WICHTIG: Diese Datei enthält KEINE echten Werte.
# Kopiere sie nach .env.local und trage deine echten API Keys ein.
# .env.local wird NIEMALS in Git committed (.gitignore schützt sie).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Stripe (Payments) ───────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_HIER_EINTRAGEN
STRIPE_SECRET_KEY=sk_test_HIER_EINTRAGEN
STRIPE_WEBHOOK_SECRET=whsec_HIER_EINTRAGEN

# STRIPE_ACTIVE=false → Stripe deaktivieren (lokal ohne Zahlung testen)
STRIPE_ACTIVE=false

# ─── Blockchain / Ethereum ────────────────────────────────────────────────────
ALCHEMY_API_KEY=HIER_EINTRAGEN
ETHERSCAN_API_KEY=HIER_EINTRAGEN

# ─── Kurs-APIs ────────────────────────────────────────────────────────────────
# CoinMarketCap: primäre Kursquelle (https://pro.coinmarketcap.com/)
COINMARKETCAP_API_KEY=HIER_EINTRAGEN

# CoinGecko: historische Kurse – optional, erhöht Rate-Limit (https://www.coingecko.com/en/api)
# COINGECKO_API_KEY=CG-HIER_EINTRAGEN

# CryptoCompare: Kurs-Fallback – optional (https://www.cryptocompare.com/)
# CRYPTOCOMPARE_API_KEY=HIER_EINTRAGEN

# ─── App-URL (für Stripe Redirect) ───────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.btcsteuerauszug.ch

# ─── Test-Wallets (nur lokal, NIEMALS committen) ──────────────────────────────
# Werden für test:realwallet verwendet – ohne diese Variablen werden die Tests übersprungen
# TEST_WALLET_1=bc1q_deine_test_wallet_hier
# TEST_WALLET_2=bc1q_zweite_test_wallet_hier
# TEST_ZPUB=zpub_dein_extended_public_key_hier
